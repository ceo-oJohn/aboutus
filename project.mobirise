            ".image-wrapper": {
              "margin-bottom": "0rem",
              "padding": "0rem",
              "@media (max-width: 767px)": {
                "padding": "0rem 0rem",
                "margin-bottom": "0rem"
              },
              "@media (min-width: 992px) and (max-width: 1200px)": {
                "padding": "0rem 0rem",
                "margin-bottom": "0rem"
              }
            },
            ".image-wrapper img": {
              "height": "100%",
              "object-fit": "cover"
            },
            ".item-mb": {
              "margin-bottom": "2rem",
              "@media (max-width: 767px)": {
                "margin-bottom": "1rem"
              }
            },
            ".card-title": {
              "text-align": "left"
            },
            ".item-content": {
              "display": "flex",
              "flex-direction": "column",
              "height": "100%",
              ".item-footer": {
                "margin-top": "auto"
              }
            }
